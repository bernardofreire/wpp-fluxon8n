    {
      "parameters": {
        "jsCode": "\nconst ctx = $('Prepare Context1').first().json;\nconst params = ctx.params || {};\n\n// Generate order ID\nconst ts = Date.now();\nconst rand = Math.floor(Math.random() * 10000).toString().padStart(4, '0');\nconst orderId = `ORD-${ts}-${rand}`;\n\n// Date in tenant timezone\nconst tzOffset = Number(ctx.tenant.timezone_offset) || -3;\nconst now = new Date();\nconst localMs = now.getTime() + tzOffset * 3600 * 1000;\nconst local = new Date(localMs);\nconst yyyy = local.getUTCFullYear();\nconst mm = String(local.getUTCMonth() + 1).padStart(2, '0');\nconst dd = String(local.getUTCDate()).padStart(2, '0');\nconst hh = String(local.getUTCHours()).padStart(2, '0');\nconst mi = String(local.getUTCMinutes()).padStart(2, '0');\nconst dateStr = `${yyyy}-${mm}-${dd} ${hh}:${mi}`;\n\nconst items = params.items || [];\nconst cutleryStr = params.cutlery ? 'Sim' : 'Não';\n\nconst rows = items.map(it => ({\n  'Date': dateStr,\n  'Order ID': orderId,\n  'Phone Number': params.customer_phone || '',\n  'User': params.customer_name || '',\n  'Item_id': String(it.product_id || ''),\n  'Item': it.product_name || '',\n  'Quantity': String(it.quantity || 1),\n  'Price': String(it.unit_price || 0),\n  'Status': 'pending_payment',\n  'Address': params.delivery_address || '',\n  'Observation': params.observation || '',\n  'Cutlery': cutleryStr,\n  'Payment Method': params.payment_method || '',\n  'Change For': String(params.change_for || '')\n}));\n\nreturn rows.map(r => ({ json: { ...r, _order_id: orderId } }));\n"
      },
