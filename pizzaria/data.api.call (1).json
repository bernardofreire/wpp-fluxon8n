        "jsCode": "\nconst rows = $input.all().map(i => i.json).filter(r => r.id !== undefined && r.id !== '');\nconst params = $('Prepare Context1').first().json.params || {};\nconst sizeCode = String(params.size_code || '').toLowerCase();\n\nconst colMap = {\n  'p': 'price_p',\n  'm': 'price_m',\n  'g': 'price_g',\n  'f': 'price_f'\n};\nconst col = colMap[sizeCode] || 'price_m';\n\nconst borders = rows\n  .filter(r => String(r.ativo).toUpperCase() === 'TRUE' || r.ativo === true)\n  .map(r => ({\n    id: String(r.id),\n    name: r.name || '',\n    price: Number(r[col]) || 0\n  }));\n\nreturn [{ json: { borders, count: borders.length, size_code: sizeCode } }];\n"
