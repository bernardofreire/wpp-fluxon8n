      "parameters": {
        "jsCode": "\nconst trigger = $('Trigger').first().json;\nconst configRows = $('Load Tenant Config1').all();\n\nif (configRows.length === 0 || !configRows[0].json) {\n  throw new Error(`Tenant não encontrado: ${trigger.tenant_id}`);\n}\n\nconst cfg = configRows[0].json;\n\n// Garantir defaults razoáveis\nconst tenant = {\n  tenant_id: cfg.tenant_id || trigger.tenant_id,\n  display_name: cfg.display_name || '',\n  sheets_doc_id: cfg.sheets_doc_id || '',\n  clients_sheet: cfg.clients_sheet || 'Clients',\n  orderlist_sheet: cfg.orderlist_sheet || 'Order List',\n  catalog_sheet: cfg.catalog_sheet || 'Worksheet',\n  hours_sheet: cfg.hours_sheet || 'horario_funcionamento',\n  phone_number_id: cfg.phone_number_id || '',\n  catalog_id: cfg.catalog_id || '',\n  timezone_offset: Number(cfg.timezone_offset) || -3\n};\n\nreturn [{\n  json: {\n    tenant,\n    operation: trigger.operation,\n    params: trigger.params || {}\n  }\n}];\n"
