    {
      "parameters": {
        "jsCode": "\nconst rows = $input.all().map(i => i.json).filter(r => r['Order ID']);\nconst params = $('Prepare Context1').first().json.params || {};\nconst limit = Number(params.limit) || 5;\n\nif (rows.length === 0) {\n  return [{ json: { orders: [], count: 0 } }];\n}\n\nconst grouped = {};\nfor (const r of rows) {\n  const id = String(r['Order ID']);\n  if (!grouped[id]) {\n    grouped[id] = {\n      order_id: id,\n      created_at: r['Date'] || '',\n      customer_phone: r['Phone Number'] || '',\n      customer_name: r['User'] || '',\n      delivery_address: r['Address'] || '',\n      status: r['Status'] || '',\n      observation: r['Observation'] || '',\n      cutlery: (r['Cutlery'] === 'Sim'),\n      payment_method: r['Payment Method'] || '',\n      change_for: Number(r['Change For']) || 0,\n      items: [],\n      total: 0\n    };\n  }\n  const qty = Number(r['Quantity']) || 0;\n  const price = Number(r['Price']) || 0;\n  grouped[id].items.push({\n    product_id: r['Item_id'] || '',\n    product_name: r['Item'] || '',\n    quantity: qty,\n    unit_price: price,\n    line_total: qty * price\n  });\n  grouped[id].total += qty * price;\n}\n\nconst list = Object.values(grouped)\n  .sort((a, b) => String(b.created_at).localeCompare(String(a.created_at)))\n  .slice(0, limit);\n\nreturn [{ json: { orders: list, count: list.length } }];\n"
      },
