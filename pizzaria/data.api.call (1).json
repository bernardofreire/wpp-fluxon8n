    {
      "parameters": {
        "jsCode": "\nconst items = $input.all();\nconst params = $('Prepare Context1').first().json.params;\nconst phone = params.phone || '';\n\nlet exists = false, customer_name = '', street = '', district = '', zip_ = '', last_state = '', contexto = {};\n\nif (items.length > 0 && items[0].json && items[0].json['Phone Number']) {\n  const row = items[0].json;\n  exists = true;\n  customer_name = row['User Name'] || '';\n  street = row['Address'] || '';\n  district = row['District'] || '';\n  zip_ = row['Zip'] || '';\n  last_state = row['Last State'] || '';\n  try { contexto = row['Contexto'] ? JSON.parse(row['Contexto']) : {}; }\n  catch(e) { contexto = {}; }\n}\n\nconst has_full_address = Boolean(street && district && zip_);\n\nreturn [{\n  json: {\n    exists,\n    customer_phone: phone,\n    customer_name,\n    street, district, zip: zip_,\n    has_full_address,\n    last_state, contexto\n  }\n}];\n"
      },
