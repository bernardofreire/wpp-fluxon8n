    {
      "parameters": {
        "jsCode": "\nconst rows = $input.all().map(i => i.json).filter(r => r.id);\nconst params = $('Prepare Context1').first().json.params || {};\nconst requestedIds = params.product_ids || [];\nconst filterById = requestedIds.length > 0;\nconst idsSet = new Set(requestedIds.map(x => String(x)));\n\nconst items = rows\n  .filter(r => !filterById || idsSet.has(String(r.id)))\n  .map(r => ({\n    product_id: String(r.id),\n    name: r.title || '',\n    description: r.description || '',\n    price: Number(r.price) || 0,\n    available: String(r.availability).toLowerCase() === 'in stock',\n    image_link: r.image_link || ''\n  }));\n\nreturn [{ json: { items, count: items.length } }];\n"
      },
