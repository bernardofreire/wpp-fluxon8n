        "jsCode": "\nconst rows = $input.all().map(i => i.json).filter(r => r.id);\nconst params = $('Prepare Context1').first().json.params || {};\nconst sizeCode = String(params.size_code || '').toLowerCase();\n\nconst colMap = {\n  'p': 'adicional_p',\n  'm': 'adicional_m',\n  'g': 'adicional_g',\n  'f': 'adicional_f'\n};\nconst col = colMap[sizeCode] || 'adicional_m';\n\nconst flavors = rows\n  .filter(r => String(r.ativo).toUpperCase() === 'TRUE' || r.ativo === true)\n  .map(r => ({\n    id: String(r.id),\n    name: r.name || '',\n    description: r.description || '',\n    adicional: Number(r[col]) || 0\n  }));\n\nreturn [{ json: { flavors, count: flavors.length, size_code: sizeCode } }];\n"
