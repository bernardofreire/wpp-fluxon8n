    {
      "parameters": {
        "jsCode": "\nconst rows = $input.all().map(i => i.json).filter(r => r.dia_semana !== undefined && r.dia_semana !== '');\nconst ctx = $('Prepare Context1').first().json;\nconst tzOffset = Number(ctx.tenant.timezone_offset) || -3;\n\nconst now = new Date();\nconst localMs = now.getTime() + tzOffset * 3600 * 1000;\nconst local = new Date(localMs);\nconst dow = local.getUTCDay();\nconst hh = local.getUTCHours();\nconst mm = local.getUTCMinutes();\nconst nowMin = hh * 60 + mm;\n\nconst todayBlocks = rows.filter(r => Number(r.dia_semana) === dow);\n\nfunction parseHM(hm) {\n  const [h, m] = String(hm).split(':').map(Number);\n  return h * 60 + (m || 0);\n}\n\nlet isOpen = false;\nfor (const b of todayBlocks) {\n  if (nowMin >= parseHM(b.hora_inicio) && nowMin < parseHM(b.hora_fim)) {\n    isOpen = true;\n    break;\n  }\n}\n\nlet nextOpenMsg = '';\nif (!isOpen) {\n  const dowNames = ['domingo','segunda','terça','quarta','quinta','sexta','sábado'];\n  const remainingToday = todayBlocks\n    .filter(b => parseHM(b.hora_inicio) > nowMin)\n    .sort((a, b) => parseHM(a.hora_inicio) - parseHM(b.hora_inicio));\n\n  if (remainingToday.length > 0) {\n    nextOpenMsg = `Hoje abrimos às ${remainingToday[0].hora_inicio}.`;\n  } else {\n    for (let i = 1; i <= 7; i++) {\n      const td = (dow + i) % 7;\n      const blocks = rows.filter(r => Number(r.dia_semana) === td)\n        .sort((a, b) => parseHM(a.hora_inicio) - parseHM(b.hora_inicio));\n      if (blocks.length > 0) {\n        nextOpenMsg = `Abrimos ${dowNames[td]} às ${blocks[0].hora_inicio}.`;\n        break;\n      }\n    }\n    if (!nextOpenMsg) nextOpenMsg = 'Consulte nossos horários.';\n  }\n}\n\nreturn [{ json: { is_open: isOpen, next_open_msg: nextOpenMsg } }];\n"
      },
