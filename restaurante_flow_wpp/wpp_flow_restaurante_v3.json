        "item_6_id": { "type": "string", "__example__": "" }, "item_7_id": { "type": "string", "__example__": "" }, "item_8_id": { "type": "string", "__example__": "" }, "item_9_id": { "type": "string", "__example__": "" }, "item_10_id": { "type": "string", "__example__": "" },
        "qty_1": { "type": "string", "__example__": "1" }, "qty_2": { "type": "string", "__example__": "0" }, "qty_3": { "type": "string", "__example__": "0" }, "qty_4": { "type": "string", "__example__": "0" }, "qty_5": { "type": "string", "__example__": "0" },
        "qty_6": { "type": "string", "__example__": "0" }, "qty_7": { "type": "string", "__example__": "0" }, "qty_8": { "type": "string", "__example__": "0" }, "qty_9": { "type": "string", "__example__": "0" }, "qty_10": { "type": "string", "__example__": "0" },
        "observacao": { "type": "string", "__example__": "" },
        "talheres": { "type": "string", "__example__": "sim" }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "Dados de Entrega" },
          { "type": "TextCaption", "text": "Preencha os dados para entrega do seu pedido." },
          {
            "type": "TextInput", "name": "cep", "label": "CEP", "input-type": "text",
            "required": true, "min-chars": 8, "max-chars": 8, "helper-text": "8 dígitos, somente números"
          },
          { "type": "TextInput", "name": "endereco", "label": "Endereço", "input-type": "text", "required": true },
          { "type": "TextInput", "name": "numero", "label": "Nº", "input-type": "text", "required": true },
          { "type": "TextInput", "name": "complemento", "label": "Complemento", "input-type": "text", "required": false, "helper-text": "Apto, bloco, sala..." },
          { "type": "TextInput", "name": "referencia", "label": "Referência", "input-type": "text", "required": false },
          {
            "type": "RadioButtonsGroup", "name": "tipo_pagamento", "label": "Tipo de pagamento", "required": true,
            "data-source": [
              { "id": "entrega", "title": "Pagamento na Entrega" },
              { "id": "online", "title": "Pagamento Online" }
            ]
          },
          {
            "type": "If",
            "condition": "${form.tipo_pagamento} == 'entrega'",
            "then": [
              {
                "type": "Dropdown", "name": "pagamento_entrega", "label": "Forma de pagamento", "required": true,
                "data-source": [
                  { "id": "dinheiro", "title": "Dinheiro" },
                  { "id": "credito", "title": "Cartão de Crédito" },
                  { "id": "debito", "title": "Cartão de Débito" }
                ]
              },
              {
                "type": "If",
                "condition": "${form.pagamento_entrega} == 'dinheiro'",
                "then": [
                  { "type": "TextInput", "name": "troco", "label": "Troco para quanto?", "input-type": "number", "required": false }
                ]
              }
            ]
          },
          {
            "type": "If",
            "condition": "${form.tipo_pagamento} == 'online'",
            "then": [
              {
                "type": "Dropdown", "name": "pagamento_online", "label": "Forma de pagamento", "required": true,
                "data-source": [
                  { "id": "pix", "title": "PIX" },
                  { "id": "credito_online", "title": "Cartão de Crédito" },
                  { "id": "debito_online", "title": "Cartão de Débito" }
                ]
              }
            ]
          },
          {
            "type": "If",
            "condition": "${form.tipo_pagamento} == 'online'",
            "then": [
              {
                "type": "Footer",
                "label": "Gerar Link de Pagamento",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "flow_token": "${data.flow_token}",
                    "item_1_id": "${data.item_1_id}", "item_2_id": "${data.item_2_id}", "item_3_id": "${data.item_3_id}", "item_4_id": "${data.item_4_id}", "item_5_id": "${data.item_5_id}",
                    "item_6_id": "${data.item_6_id}", "item_7_id": "${data.item_7_id}", "item_8_id": "${data.item_8_id}", "item_9_id": "${data.item_9_id}", "item_10_id": "${data.item_10_id}",
                    "qty_1": "${data.qty_1}", "qty_2": "${data.qty_2}", "qty_3": "${data.qty_3}", "qty_4": "${data.qty_4}", "qty_5": "${data.qty_5}",
                    "qty_6": "${data.qty_6}", "qty_7": "${data.qty_7}", "qty_8": "${data.qty_8}", "qty_9": "${data.qty_9}", "qty_10": "${data.qty_10}",
                    "observacao": "${data.observacao}", "talheres": "${data.talheres}",
                    "cep": "${form.cep}", "endereco": "${form.endereco}", "numero": "${form.numero}", "complemento": "${form.complemento}", "referencia": "${form.referencia}",
                    "tipo_pagamento": "${form.tipo_pagamento}", "pagamento_entrega": "${form.pagamento_entrega}", "pagamento_online": "${form.pagamento_online}", "troco": "${form.troco}"
                  }
                }
              }
            ],
            "else": [
              {
                "type": "Footer",
                "label": "Confirmar Pedido",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "flow_token": "${data.flow_token}",
                    "item_1_id": "${data.item_1_id}", "item_2_id": "${data.item_2_id}", "item_3_id": "${data.item_3_id}", "item_4_id": "${data.item_4_id}", "item_5_id": "${data.item_5_id}",
                    "item_6_id": "${data.item_6_id}", "item_7_id": "${data.item_7_id}", "item_8_id": "${data.item_8_id}", "item_9_id": "${data.item_9_id}", "item_10_id": "${data.item_10_id}",
                    "qty_1": "${data.qty_1}", "qty_2": "${data.qty_2}", "qty_3": "${data.qty_3}", "qty_4": "${data.qty_4}", "qty_5": "${data.qty_5}",
                    "qty_6": "${data.qty_6}", "qty_7": "${data.qty_7}", "qty_8": "${data.qty_8}", "qty_9": "${data.qty_9}", "qty_10": "${data.qty_10}",
                    "observacao": "${data.observacao}", "talheres": "${data.talheres}",
                    "cep": "${form.cep}", "endereco": "${form.endereco}", "numero": "${form.numero}", "complemento": "${form.complemento}", "referencia": "${form.referencia}",
                    "tipo_pagamento": "${form.tipo_pagamento}", "pagamento_entrega": "${form.pagamento_entrega}", "pagamento_online": "${form.pagamento_online}", "troco": "${form.troco}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}